# Vite / browser — only VITE_* is bundled. Never service_role or Gemini here.
# Server secrets: ../.env

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Optional: dev proxy for /api (default http://127.0.0.1:3000)
# VITE_API_PROXY=http://127.0.0.1:3000

# Set CLIENT_APP_URL in ../.env to match your Vite URL (e.g. http://localhost:5173)
